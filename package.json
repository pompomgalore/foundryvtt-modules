{
  "name": "foundryvtt-modules",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "generate:modules": "tsx scripts/generate-modules-list.ts",
    "dev": "npm run generate:modules && vite",
    "build": "vue-tsc && vite build && npm run generate:modules",
    "preview": "vite preview",
    "upgrade": "npm run upgrade:git && npm run upgrade:npm",
    "upgrade:git": "git pull origin main",
    "upgrade:npm": "npx --yes npm-check-updates -u -t minor && npm install --no-audit --no-fund --no-update-notifier"
  },
  "dependencies": {
    "marked": "^11.2.0",
    "vue": "^3.5.33",
    "vue-router": "^4.6.4"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.2.4",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vite": "^5.4.21",
    "vue-tsc": "^2.2.12"
  }
}
